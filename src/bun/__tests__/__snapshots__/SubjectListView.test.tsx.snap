// Bun Snapshot v1, https://bun.sh/docs/test/snapshots

exports[`SubjectListView snapshots loading state 1`] = `"<div class="p-8 text-center text-gray-400">Loading subjects...</div>"`;

exports[`SubjectListView snapshots error state 1`] = `"<div class="p-8 text-center text-red-400">Error: Server down</div>"`;

exports[`SubjectListView snapshots content state with subjects 1`] = `"<div class="h-screen flex flex-col bg-gray-900 text-gray-100"><header class="bg-gray-800 border-b border-gray-700 px-6 py-4 flex items-center justify-between shrink-0"><div><h1 class="text-2xl font-bold text-indigo-400">CourseReader</h1><p class="text-sm text-gray-400 mt-0.5">Desktop study app</p></div><div class="flex gap-2"><button class="px-3 py-1.5 text-sm bg-gray-700 hover:bg-gray-600 rounded-lg transition-colors">Bookmarks</button><button class="px-3 py-1.5 text-sm bg-gray-700 hover:bg-gray-600 rounded-lg transition-colors">Settings</button></div></header><main class="px-6 py-8 overflow-y-auto flex-1"><div class="grid gap-4"><button class="text-left bg-gray-800 hover:bg-gray-750 border border-gray-700 rounded-xl p-5 transition-colors group cursor-pointer"><div class="flex items-start justify-between"><div class="flex-1 min-w-0"><h2 class="text-lg font-semibold text-white group-hover:text-indigo-400 transition-colors">Mathematics 101</h2><div class="mt-1 flex flex-wrap gap-2 text-xs text-gray-400"><span class="bg-gray-700 px-2 py-0.5 rounded">beginner</span><span class="bg-gray-700 px-2 py-0.5 rounded">20h</span><span class="bg-gray-700 px-2 py-0.5 rounded">2 modules</span></div><ul class="mt-3 space-y-1"><li class="text-sm text-gray-400 flex items-start gap-2"><span class="text-indigo-500 mt-0.5 shrink-0">→</span><span>Understand algebra</span></li><li class="text-sm text-gray-400 flex items-start gap-2"><span class="text-indigo-500 mt-0.5 shrink-0">→</span><span>Solve equations</span></li></ul></div><span class="text-gray-600 group-hover:text-indigo-400 ml-4 mt-1 shrink-0">→</span></div></button><button class="text-left bg-gray-800 hover:bg-gray-750 border border-gray-700 rounded-xl p-5 transition-colors group cursor-pointer"><div class="flex items-start justify-between"><div class="flex-1 min-w-0"><h2 class="text-lg font-semibold text-white group-hover:text-indigo-400 transition-colors">Physics</h2><div class="mt-1 flex flex-wrap gap-2 text-xs text-gray-400"><span class="bg-gray-700 px-2 py-0.5 rounded">intermediate</span><span class="bg-gray-700 px-2 py-0.5 rounded">30h</span><span class="bg-gray-700 px-2 py-0.5 rounded">1 modules</span></div></div><span class="text-gray-600 group-hover:text-indigo-400 ml-4 mt-1 shrink-0">→</span></div></button></div></main></div>"`;

exports[`SubjectListView snapshots empty state (no subjects) 1`] = `"<div class="h-screen flex flex-col bg-gray-900 text-gray-100"><header class="bg-gray-800 border-b border-gray-700 px-6 py-4 flex items-center justify-between shrink-0"><div><h1 class="text-2xl font-bold text-indigo-400">CourseReader</h1><p class="text-sm text-gray-400 mt-0.5">Desktop study app</p></div><div class="flex gap-2"><button class="px-3 py-1.5 text-sm bg-gray-700 hover:bg-gray-600 rounded-lg transition-colors">Bookmarks</button><button class="px-3 py-1.5 text-sm bg-gray-700 hover:bg-gray-600 rounded-lg transition-colors">Settings</button></div></header><main class="px-6 py-8 overflow-y-auto flex-1"><div class="text-center py-12 text-gray-500">No subjects found. Add subjects to the subjects/ directory.</div><div class="grid gap-4"></div></main></div>"`;
