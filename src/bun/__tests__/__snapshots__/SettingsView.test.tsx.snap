// Bun Snapshot v1, https://bun.sh/docs/test/snapshots

exports[`SettingsView snapshots initial render (checking key status) 1`] = `"<div class="min-h-screen bg-gray-900 text-gray-100"><header class="bg-gray-800 border-b border-gray-700 px-4 py-2 flex items-center justify-between"><button class="text-gray-400 hover:text-white transition-colors">← Back</button><h2 class="text-sm font-medium">Settings</h2><div class="w-16"></div></header><main class="max-w-lg mx-auto px-6 py-8"><section class="bg-gray-800 rounded-xl p-6 mb-6"><h3 class="text-lg font-semibold mb-4">Gemini API Key</h3><p class="text-sm text-gray-400 mb-4">Required for the Ask AI feature. Get a free key at <a href="https://aistudio.google.com/apikey" target="_blank" class="text-indigo-400 hover:underline" rel="noreferrer">Google AI Studio</a>.</p><div class="flex gap-2"><input type="password" placeholder="Enter your Gemini API key" class="flex-1 bg-gray-700 border border-gray-600 rounded-lg px-3 py-2 text-sm text-gray-200 placeholder-gray-500" value=""><button disabled="" class="px-4 py-2 bg-indigo-600 hover:bg-indigo-500 rounded-lg text-sm transition-colors disabled:opacity-50">Save</button></div></section><section class="bg-gray-800 rounded-xl p-6"><h3 class="text-lg font-semibold mb-4">About</h3><p class="text-sm text-gray-400">CourseReader v1.0</p><p class="text-sm text-gray-400">macOS desktop study app with spaced repetition.</p></section></main></div>"`;

exports[`SettingsView snapshots API key configured 1`] = `"<div class="min-h-screen bg-gray-900 text-gray-100"><header class="bg-gray-800 border-b border-gray-700 px-4 py-2 flex items-center justify-between"><button class="text-gray-400 hover:text-white transition-colors">← Back</button><h2 class="text-sm font-medium">Settings</h2><div class="w-16"></div></header><main class="max-w-lg mx-auto px-6 py-8"><section class="bg-gray-800 rounded-xl p-6 mb-6"><h3 class="text-lg font-semibold mb-4">Gemini API Key</h3><p class="text-sm text-gray-400 mb-4">Required for the Ask AI feature. Get a free key at <a href="https://aistudio.google.com/apikey" target="_blank" class="text-indigo-400 hover:underline" rel="noreferrer">Google AI Studio</a>.</p><div class="flex gap-2"><input type="password" placeholder="API key set (enter new key to change)" class="flex-1 bg-gray-700 border border-gray-600 rounded-lg px-3 py-2 text-sm text-gray-200 placeholder-gray-500" value=""><button disabled="" class="px-4 py-2 bg-indigo-600 hover:bg-indigo-500 rounded-lg text-sm transition-colors disabled:opacity-50">Save</button></div><p class="text-xs text-emerald-400 mt-2">✓ API key is configured</p></section><section class="bg-gray-800 rounded-xl p-6"><h3 class="text-lg font-semibold mb-4">About</h3><p class="text-sm text-gray-400">CourseReader v1.0</p><p class="text-sm text-gray-400">macOS desktop study app with spaced repetition.</p></section></main></div>"`;

