// Bun Snapshot v1, https://bun.sh/docs/test/snapshots

exports[`ReviewView snapshots loading state 1`] = `"<div class="p-8 text-center text-gray-400">Loading review cards...</div>"`;

exports[`ReviewView snapshots empty deck (no cards) 1`] = `"<div class="min-h-screen bg-gray-900 text-gray-100"><header class="bg-gray-800 border-b border-gray-700 px-4 py-2 flex items-center justify-between"><button class="text-gray-400 hover:text-white transition-colors">← Back</button><div class="flex items-center gap-2"><button class="px-3 py-1 text-xs rounded transition-colors bg-indigo-600 text-white">All</button><button class="px-3 py-1 text-xs rounded transition-colors bg-gray-700 hover:bg-gray-600">Due</button><button class="px-3 py-1 text-xs rounded transition-colors bg-gray-700 hover:bg-gray-600">Starred</button></div><div class="text-sm text-gray-400">0 cards</div></header><main class="max-w-xl mx-auto px-6 py-12"><div class="text-center py-12"><p class="text-gray-400 mb-4">No cards in deck.</p><p class="text-sm text-gray-500">Complete a quiz to generate SRS cards.</p></div></main></div>"`;

exports[`ReviewView snapshots card question side (initial) 1`] = `"<div class="min-h-screen bg-gray-900 text-gray-100"><header class="bg-gray-800 border-b border-gray-700 px-4 py-2 flex items-center justify-between"><button class="text-gray-400 hover:text-white transition-colors">← Back</button><div class="flex items-center gap-2"><button class="px-3 py-1 text-xs rounded transition-colors bg-indigo-600 text-white">All</button><button class="px-3 py-1 text-xs rounded transition-colors bg-gray-700 hover:bg-gray-600">Due</button><button class="px-3 py-1 text-xs rounded transition-colors bg-gray-700 hover:bg-gray-600">Starred</button></div><div class="text-sm text-gray-400">1 cards</div></header><main class="max-w-xl mx-auto px-6 py-12"><div><div class="text-xs text-gray-500 mb-2 text-center">Card 1 of 1</div><div class="bg-gray-800 rounded-xl p-8 min-h-[200px] flex flex-col items-center justify-center text-center mb-6"><div><h3 class="text-lg font-medium mb-6">What is 2+2?</h3><button class="px-6 py-2 bg-indigo-600 hover:bg-indigo-500 rounded-lg transition-colors">Show Answer</button></div></div><div class="flex justify-center gap-2"><button class="text-xs text-gray-500 hover:text-gray-400">☆ Star</button></div></div></main></div>"`;
